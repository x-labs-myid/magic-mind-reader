<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-white">

    <GridLayout rows="*">
        <!-- Canvas Background Layer -->
        <canvas:Canvas id="bgCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- UI Content Layer -->
        <GridLayout row="0" rows="auto, *, auto" class="p-6">
            <!-- Language Selector Header -->
            <StackLayout row="0" orientation="horizontal" horizontalAlignment="right" class="space-x-2">
                <Label text="{{ L('choose_lang') + ':' }}" class="text-sm text-zinc-500 dark:text-zinc-400 font-semibold self-center" />
                <Button text="{{ L('lang_en') }}" tap="selectEnglish" class="text-xs bg-zinc-100 dark:bg-zinc-800 active:bg-zinc-200 dark:active:bg-zinc-700 rounded-lg px-3 py-1 font-bold text-zinc-800 dark:text-zinc-200" />
                <Button text="{{ L('lang_id') }}" tap="selectIndonesian" class="text-xs bg-zinc-100 dark:bg-zinc-800 active:bg-zinc-200 dark:active:bg-zinc-700 rounded-lg px-3 py-1 font-bold text-zinc-800 dark:text-zinc-200" />
            </StackLayout>

            <!-- Main Menu Panel -->
            <StackLayout row="1" verticalAlignment="center" horizontalAlignment="center" class="bg-zinc-50/90 dark:bg-zinc-900/60 border border-zinc-200/50 dark:border-zinc-800/30 rounded-3xl p-8 max-w-sm text-center shadow-2xl">
                <!-- Branding Icon (FontAwesome hand-sparkles) -->
                <Label text="&#xe05d;" class="fas text-6xl text-zinc-900 dark:text-white mb-4" />
                
                <!-- Game Title -->
                <Label text="{{ L('title') }}" class="text-3xl font-extrabold text-zinc-900 dark:text-white mb-2" textWrap="true" />
                
                <!-- Subtitle -->
                <Label text="{{ L('subtitle') }}" class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed mb-8" textWrap="true" />

                <!-- Let's Play Button -->
                <Button tap="startPlay" class="bg-zinc-950 dark:bg-white text-white dark:text-zinc-950 font-extrabold text-lg rounded-2xl py-4 shadow-lg shadow-zinc-950/10 dark:shadow-white/5">
                    <FormattedString>
                        <Span text="&#xf04b;" class="fas" />
                        <Span text="&nbsp;&nbsp; " />
                        <Span text="{{ L('btn_play') }}" />
                    </FormattedString>
                </Button>
            </StackLayout>

            <!-- Footer -->
            <StackLayout row="2" class="text-center">
                <Label text="{{ L('created_by') }}" class="text-xs text-zinc-400 dark:text-zinc-600" />
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
