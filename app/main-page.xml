<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    class="bg-indigo-950 text-white">

    <GridLayout rows="*">
        <!-- Canvas Background Layer -->
        <canvas:Canvas id="bgCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- UI Content Layer -->
        <GridLayout row="0" rows="auto, *, auto" class="p-6">
            <!-- Language Selector Header -->
            <StackLayout row="0" orientation="horizontal" horizontalAlignment="right" class="space-x-2">
                <Label text="{{ L('choose_lang') + ':' }}" class="text-sm text-indigo-200/70 font-semibold self-center" />
                <Button text="{{ L('lang_en') }}" tap="selectEnglish" class="text-xs bg-indigo-800/50 active:bg-indigo-700/80 rounded-lg px-3 py-1 font-bold text-indigo-200" />
                <Button text="{{ L('lang_id') }}" tap="selectIndonesian" class="text-xs bg-indigo-800/50 active:bg-indigo-700/80 rounded-lg px-3 py-1 font-bold text-indigo-200" />
            </StackLayout>

            <!-- Main Menu Panel -->
            <StackLayout row="1" verticalAlignment="center" horizontalAlignment="center" class="bg-indigo-900/60 border border-indigo-500/30 rounded-3xl p-8 max-w-sm text-center shadow-2xl">
                <!-- Colorful Emoji/Icon -->
                <Label text="🔮" class="text-6xl mb-4" />
                
                <!-- Game Title -->
                <Label text="{{ L('title') }}" class="text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-400 mb-2" textWrap="true" />
                
                <!-- Subtitle -->
                <Label text="{{ L('subtitle') }}" class="text-indigo-200 text-sm leading-relaxed mb-8" textWrap="true" />
                <Button tap="startPlay" class="bg-gradient-to-r from-pink-500 to-purple-600 active:from-pink-600 active:to-purple-700 text-white font-extrabold text-lg rounded-2xl py-4 shadow-lg shadow-pink-500/20">
                    <FormattedString>
                        <Span text="&#xf04b;" class="fas" />
                        <Span text="&nbsp;&nbsp; " />
                        <Span text="{{ L('btn_play') }}" />
                    </FormattedString>
                </Button>            </StackLayout>

            <!-- Footer -->
            <StackLayout row="2" class="text-center">
                <Label text="{{ L('created_by') }}" class="text-xs text-indigo-300/40" />
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
