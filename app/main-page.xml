<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    class="bg-indigo-950 text-white">

    <GridLayout rows="*">
        <!-- Canvas Background Layer -->
        <canvas:Canvas id="bgCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- UI Content Layer -->
        <GridLayout row="0" rows="auto, *, auto" class="p-6">
            <!-- Header (Language & About) -->
            <GridLayout row="0" columns="auto, *" class="w-full">
                <!-- About App Button (FontAwesome info-circle) -->
                <Button col="0" tap="goAbout" class="text-lg btn-header active:bg-indigo-800 rounded-full w-12 h-12 text-amber-300 border shadow-md">
                    <FormattedString>
                        <Span text="&#xf05a;" class="fas" />
                    </FormattedString>
                </Button>

                <!-- Language Selector -->
                <StackLayout col="1" orientation="horizontal" horizontalAlignment="right" class="space-x-2">
                    <Label text="{{ L('choose_lang') + ':' }}" class="text-xs text-indigo-300 font-bold self-center mr-1" />
                    <Button text="{{ L('lang_en') }}" tap="selectEnglish" class="text-xs btn-lang active:bg-indigo-700 border rounded-xl px-3 py-1.5 font-extrabold text-amber-300 shadow-sm" />
                    <Button text="{{ L('lang_id') }}" tap="selectIndonesian" class="text-xs btn-lang active:bg-indigo-700 border rounded-xl px-3 py-1.5 font-extrabold text-amber-300 shadow-sm" />
                </StackLayout>
            </GridLayout>

            <!-- Main Menu Card Panel -->
            <StackLayout row="1" verticalAlignment="center" horizontalAlignment="center" class="card-panel border-2 rounded-3xl p-7 max-w-sm text-center shadow-2xl">
                <StackLayout class="bg-gradient-to-tr from-amber-400 to-pink-500 rounded-full w-20 h-20 self-center mb-4 p-4 badge-magic" verticalAlignment="center" horizontalAlignment="center">
                    <Label text="&#xe05d;" class="fas text-4xl text-white text-center" />
                </StackLayout>
                
                <!-- Game Title -->
                <Label text="{{ L('title') }}" class="text-3xl font-black text-amber-300 mb-2" textWrap="true" />
                
                <!-- Subtitle -->
                <Label text="{{ L('subtitle') }}" class="text-indigo-100 text-sm leading-relaxed mb-6 font-semibold" textWrap="true" />

                <!-- Let's Play Button (Vibrant Pink/Amber Gradient Accent) -->
                <Button tap="startPlay" class="bg-amber-400 active:bg-amber-300 text-indigo-950 font-black text-xl rounded-2xl py-4 btn-play border-2 border-amber-300">
                    <FormattedString>
                        <Span text="&#xf04b;" class="fas text-amber-950" />
                        <Span text="&nbsp;&nbsp; " />
                        <Span text="{{ L('btn_play') }}" />
                    </FormattedString>
                </Button>
            </StackLayout>

            <!-- Footer -->
            <StackLayout row="2" class="text-center pb-2">
                <Label text="{{ L('created_by') }}" class="text-xs footer-text font-bold" />
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
