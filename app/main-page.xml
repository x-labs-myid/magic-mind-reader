<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    backgroundColor="#ffffff"
    color="#000000">

    <GridLayout rows="*">
        <!-- Canvas Background Layer -->
        <canvas:Canvas id="bgCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- Main Content Layer -->
        <GridLayout row="0" rows="auto, *" padding="16">
            <!-- Header Bar -->
            <GridLayout row="0" columns="auto, *, auto" width="100%" margin="0 0 10 0">
                <!-- Top Left: Language Selector Button (Replaces Magic 2.0 Badge) -->
                <StackLayout col="0" tap="toggleSettings" backgroundColor="#00e5ff" borderColor="#000000" borderWidth="2" borderRadius="16" padding="6 14" verticalAlignment="center">
                    <Label text="{{ currentLangBadge }}" color="#000000" fontWeight="bold" fontSize="13" verticalAlignment="center" />
                </StackLayout>

                <!-- Top Right Actions: Sound & About -->
                <StackLayout col="2" orientation="horizontal" horizontalAlignment="right" verticalAlignment="center">
                    <!-- Sound Toggle Button -->
                    <StackLayout tap="toggleSound" backgroundColor="#ff4081" borderWidth="2" borderColor="#000000" borderRadius="22" width="44" height="44" margin="0 8 0 0" verticalAlignment="center" horizontalAlignment="center">
                        <Label text="{{ soundIcon }}" class="fas" fontSize="16" color="#ffffff" textAlignment="center" verticalAlignment="center" />
                    </StackLayout>

                    <!-- Info / About Button -->
                    <StackLayout tap="goAbout" backgroundColor="#a855f7" borderWidth="2" borderColor="#000000" borderRadius="22" width="44" height="44" verticalAlignment="center" horizontalAlignment="center">
                        <Label text="&#xf05a;" class="fas" fontSize="16" color="#ffffff" textAlignment="center" verticalAlignment="center" />
                    </StackLayout>
                </StackLayout>
            </GridLayout>

            <!-- Center Content -->
            <ScrollView row="1" verticalAlignment="center">
                <StackLayout horizontalAlignment="stretch" verticalAlignment="center">
                    <!-- Main Card -->
                    <StackLayout backgroundColor="#ffffff" borderWidth="3" borderColor="#000000" borderRadius="24" padding="24 20" margin="10 4">
                        <!-- Orange Hand Icon Circle -->
                        <StackLayout backgroundColor="#ff9800" borderWidth="2" borderColor="#000000" borderRadius="36" width="72" height="72" horizontalAlignment="center" margin="0 0 16 0" verticalAlignment="center">
                            <Label text="&#xf25a;" class="fas" fontSize="36" color="#000000" textAlignment="center" verticalAlignment="center" />
                        </StackLayout>
                        
                        <!-- Title -->
                        <Label text="{{ L('title') }}" fontSize="24" fontWeight="bold" color="#000000" textAlignment="center" textWrap="true" margin="0 0 12 0" />
                        
                        <!-- Subtitle Highlight Box -->
                        <StackLayout backgroundColor="#fef9c3" borderRadius="16" padding="14 16" margin="0 0 20 0">
                            <Label text="{{ L('subtitle') }}" fontSize="14" fontWeight="bold" color="#000000" textAlignment="center" textWrap="true" />
                        </StackLayout>

                        <!-- Start Play Button with Explicit Height & FontAwesome Icon -->
                        <Button tap="startPlay" height="58" backgroundColor="#ffee00" color="#000000" borderRadius="29" borderWidth="3" borderColor="#000000" verticalAlignment="center">
                            <FormattedString>
                                <Span text="&#xf0d0;" class="fas" fontSize="16" />
                                <Span text="  " />
                                <Span text="{{ L('btn_play') }}" fontSize="18" fontWeight="bold" />
                            </FormattedString>
                        </Button>
                    </StackLayout>

                    <!-- How It Works Accordion Panel -->
                    <StackLayout backgroundColor="#0b2528" borderWidth="3" borderColor="#000000" borderRadius="18" padding="14 16" margin="12 4 0 4">
                        <GridLayout columns="*, auto" tap="toggleHowItWorks" width="100%">
                            <StackLayout col="0" orientation="horizontal" verticalAlignment="center">
                                <Label text="&#xf0eb;" class="fas" fontSize="14" color="#ffee00" verticalAlignment="center" margin="0 8 0 0" />
                                <Label text="{{ L('how_it_works') }}" fontSize="14" fontWeight="bold" color="#ffffff" verticalAlignment="center" />
                            </StackLayout>
                            <Label col="1" text="{{ accordionIcon }}" fontSize="12" fontWeight="bold" color="#ffee00" verticalAlignment="center" />
                        </GridLayout>

                        <!-- Expandable Explanation -->
                        <StackLayout visibility="{{ isHowItWorksOpen ? 'visible' : 'collapsed' }}" margin="10 0 0 0" padding="10 0 0 0">
                            <Label text="{{ L('about_desc') }}" fontSize="12" color="#e0f2fe" textWrap="true" />
                        </StackLayout>
                    </StackLayout>
                </StackLayout>
            </ScrollView>
        </GridLayout>

        <!-- Settings Overlay / Language Dialog -->
        <GridLayout row="0" visibility="{{ isSettingsOpen ? 'visible' : 'collapsed' }}" backgroundColor="rgba(0, 0, 0, 0.6)" padding="20">
            <StackLayout backgroundColor="#ffffff" borderWidth="3" borderColor="#000000" borderRadius="24" padding="24 20" verticalAlignment="center" horizontalAlignment="stretch">
                <StackLayout orientation="horizontal" horizontalAlignment="center" margin="0 0 20 0">
                    <Label text="&#xf013;" class="fas" fontSize="18" color="#000000" verticalAlignment="center" margin="0 8 0 0" />
                    <Label text="Language / Bahasa" fontSize="20" fontWeight="bold" color="#000000" verticalAlignment="center" />
                </StackLayout>

                <Button text="🇬🇧  English" tap="selectEnglish" height="52" backgroundColor="#00e5ff" color="#000000" fontSize="16" fontWeight="bold" borderRadius="20" borderWidth="2" borderColor="#000000" margin="0 0 12 0" verticalAlignment="center" />
                <Button text="🇮🇩  Bahasa Indonesia" tap="selectIndonesian" height="52" backgroundColor="#ffee00" color="#000000" fontSize="16" fontWeight="bold" borderRadius="20" borderWidth="2" borderColor="#000000" margin="0 0 12 0" verticalAlignment="center" />

                <Button text="{{ L('btn_back') }}" tap="toggleSettings" height="52" backgroundColor="#ff4081" color="#ffffff" fontSize="16" fontWeight="bold" borderRadius="20" borderWidth="2" borderColor="#000000" verticalAlignment="center" />
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
