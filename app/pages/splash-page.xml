<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    backgroundColor="#ffffff"
    color="#000000">

    <GridLayout rows="*">
        <!-- Background Canvas -->
        <canvas:Canvas id="splashCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- Main Splash Content -->
        <GridLayout row="0" rows="*, auto" padding="20">
            <StackLayout row="0" verticalAlignment="center" horizontalAlignment="center">
                <Image src="~/assets/images/logo.png" width="140" height="140" horizontalAlignment="center" margin="0 0 16 0" />
                <Label text="{{ L('title') }}" fontSize="28" fontWeight="bold" color="#000000" textAlignment="center" textWrap="true" margin="0 0 12 0" />
                
                <StackLayout backgroundColor="#ffee00" borderWidth="2" borderColor="#000000" borderRadius="18" padding="6 16" horizontalAlignment="center">
                    <StackLayout orientation="horizontal" verticalAlignment="center">
                        <Label text="&#xf005;" class="fas" fontSize="10" color="#000000" verticalAlignment="center" margin="0 6 0 0" />
                        <Label text="Magic Mind Reader" fontSize="12" fontWeight="bold" color="#000000" verticalAlignment="center" />
                        <Label text="&#xf005;" class="fas" fontSize="10" color="#000000" verticalAlignment="center" margin="0 0 0 6" />
                    </StackLayout>
                </StackLayout>
            </StackLayout>

            <StackLayout row="1" margin="0 0 24 0" horizontalAlignment="center">
                <ActivityIndicator busy="true" color="#ff9800" margin="0 0 8 0" horizontalAlignment="center" />
                <Label text="{{ L('loading_push') }}" fontSize="13" color="#475569" fontWeight="bold" textAlignment="center" />
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
