<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-white">

    <GridLayout rows="*">
        <!-- Confetti Canvas Background Layer -->
        <canvas:Canvas id="confettiCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- UI Content Layer -->
        <GridLayout row="0" rows="*, auto">
            <!-- Main Content Area -->
            <StackLayout row="0" verticalAlignment="center" horizontalAlignment="center" class="px-6 text-center">
                <!-- Loading State -->
                <StackLayout visibility="{{ isLoading ? 'visible' : 'collapsed' }}" class="space-y-4">
                    <ActivityIndicator busy="true" class="text-zinc-950 dark:text-white w-16 h-16 self-center" />
                    <Label text="{{ L('loading_result') }}" class="text-zinc-700 dark:text-zinc-300 text-lg font-bold" textWrap="true" />
                </StackLayout>

                <!-- Result Revealed State -->
                <StackLayout visibility="{{ !isLoading ? 'visible' : 'collapsed' }}" class="space-y-6">
                    <!-- Branding Mini Icon (FontAwesome hand-sparkles) -->
                    <Label text="&#xe05d;" class="fas text-4xl text-zinc-950 dark:text-white text-center mb-2" />
                    <Label text="✨ {{ L('result_title') }} ✨" class="text-xl font-black text-zinc-950 dark:text-white uppercase tracking-widest" />
                    <Label text="{{ L('result_message') }}" class="text-zinc-600 dark:text-zinc-400 text-lg font-semibold" />
                    
                    <!-- Reveal Circle -->
                    <AbsoluteLayout class="w-56 h-56 self-center my-4">
                        <!-- Outer Glow Ring (via tailwind) -->
                        <StackLayout class="w-56 h-56 bg-zinc-200 dark:bg-zinc-800 rounded-full opacity-40 animate-pulse" />
                        <!-- Inner Container -->
                        <GridLayout class="w-48 h-48 bg-zinc-50 dark:bg-zinc-900 border-4 border-zinc-950 dark:border-white rounded-full shadow-2xl m-4" verticalAlignment="center" horizontalAlignment="center">
                            <Label text="{{ result }}" class="text-center text-7xl font-black text-zinc-950 dark:text-white" />
                        </GridLayout>
                    </AbsoluteLayout>
                </StackLayout>
            </StackLayout>

            <!-- Action Button Footer -->
            <StackLayout row="1" class="p-6" visibility="{{ !isLoading ? 'visible' : 'collapsed' }}">
                <Button tap="restartGame" class="bg-zinc-950 dark:bg-white text-white dark:text-zinc-950 active:bg-zinc-900 dark:active:bg-zinc-100 font-extrabold text-lg rounded-2xl py-4 shadow-lg shadow-zinc-950/10 dark:shadow-white/5">
                    <FormattedString>
                        <Span text="&#xf01e;" class="fas" />
                        <Span text="&nbsp;&nbsp; " />
                        <Span text="{{ L('btn_restart') }}" />
                    </FormattedString>
                </Button>
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
