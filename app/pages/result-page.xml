<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo"
    navigatedTo="onNavigatedTo"
    actionBarHidden="true"
    backgroundColor="#ffffff"
    color="#000000">

    <GridLayout rows="*">
        <!-- Confetti Canvas Background Layer -->
        <canvas:Canvas id="confettiCanvas" row="0" width="100%" height="100%" ready="onConfettiCanvasReady" />

        <!-- UI Content Layer -->
        <GridLayout row="0" rows="auto, *, auto" padding="16">
            <!-- Top Success Badge -->
            <StackLayout row="0" margin="4 0 0 0" horizontalAlignment="center">
                <StackLayout backgroundColor="#ffee00" borderWidth="2" borderColor="#000000" borderRadius="20" padding="8 18" horizontalAlignment="center">
                    <StackLayout orientation="horizontal" verticalAlignment="center">
                        <Label text="&#xf005;" class="fas" fontSize="13" color="#000000" verticalAlignment="center" margin="0 6 0 0" />
                        <Label text="{{ L('result_title') }}" fontSize="14" fontWeight="bold" color="#000000" verticalAlignment="center" />
                        <Label text="&#xf005;" class="fas" fontSize="13" color="#000000" verticalAlignment="center" margin="0 0 0 6" />
                    </StackLayout>
                </StackLayout>
            </StackLayout>

            <!-- Center Result Card Container & Answer History -->
            <ScrollView row="1" verticalAlignment="center">
                <StackLayout horizontalAlignment="stretch" verticalAlignment="center" margin="6 4">
                    <!-- Main Result Card -->
                    <StackLayout backgroundColor="#ffffff" borderWidth="3" borderColor="#000000" borderRadius="24" padding="20 16" textAlignment="center" horizontalAlignment="stretch" margin="0 0 12 0">
                        <!-- Subtitle -->
                        <Label fontSize="15" fontWeight="bold" color="#000000" textAlignment="center" textWrap="true" margin="0 0 14 0">
                            <FormattedString>
                                <Span text="{{ L('result_message') }}" />
                                <Span text=":" />
                            </FormattedString>
                        </Label>

                        <!-- Large Result Yellow Coin Circle (CONTAINS ICON ONLY) -->
                        <StackLayout id="resultCircle" backgroundColor="#ffee00" borderWidth="4" borderColor="#ff4081" borderRadius="60" width="120" height="120" horizontalAlignment="center" verticalAlignment="center">
                            <StackLayout borderWidth="3" borderColor="#000000" borderRadius="52" width="104" height="104" verticalAlignment="center" horizontalAlignment="center">
                                <Label id="resultIconLabel" text="{{ displayIcon }}" class="{{ displayFontClass }}" fontSize="46" color="#000000" textAlignment="center" verticalAlignment="center" horizontalAlignment="center" />
                            </StackLayout>
                        </StackLayout>

                        <!-- Item Name Label (Initially hidden, scales up with the coin animation completion) -->
                        <Label id="resultNameLabel" text="{{ displayName }}" fontSize="18" fontWeight="bold" color="#000000" textAlignment="center" textWrap="true" maxLines="2" margin="14 0 0 0" opacity="0" scaleX="0.2" scaleY="0.2" />
                    </StackLayout>

                    <!-- Simple & Elegant Answer History Row -->
                    <StackLayout horizontalAlignment="center" margin="4 0">
                        <StackLayout orientation="horizontal" horizontalAlignment="center" margin="0 0 6 0">
                            <Label text="&#xf0ae;" class="fas" fontSize="11" color="#64748b" verticalAlignment="center" margin="0 4 0 0" />
                            <Label text="{{ L('your_answers') }}" fontSize="12" fontWeight="bold" color="#64748b" verticalAlignment="center" />
                        </StackLayout>

                        <!-- Simple 5-Pill Answer Row -->
                        <StackLayout orientation="horizontal" horizontalAlignment="center">
                            <StackLayout backgroundColor="{{ ans0Bg }}" borderWidth="2" borderColor="#000000" borderRadius="10" padding="4 10" margin="0 3">
                                <Label text="{{ ans0Text }}" fontSize="12" fontWeight="bold" color="{{ ans0Fg }}" textAlignment="center" />
                            </StackLayout>
                            <StackLayout backgroundColor="{{ ans1Bg }}" borderWidth="2" borderColor="#000000" borderRadius="10" padding="4 10" margin="0 3">
                                <Label text="{{ ans1Text }}" fontSize="12" fontWeight="bold" color="{{ ans1Fg }}" textAlignment="center" />
                            </StackLayout>
                            <StackLayout backgroundColor="{{ ans2Bg }}" borderWidth="2" borderColor="#000000" borderRadius="10" padding="4 10" margin="0 3">
                                <Label text="{{ ans2Text }}" fontSize="12" fontWeight="bold" color="{{ ans2Fg }}" textAlignment="center" />
                            </StackLayout>
                            <StackLayout backgroundColor="{{ ans3Bg }}" borderWidth="2" borderColor="#000000" borderRadius="10" padding="4 10" margin="0 3">
                                <Label text="{{ ans3Text }}" fontSize="12" fontWeight="bold" color="{{ ans3Fg }}" textAlignment="center" />
                            </StackLayout>
                            <StackLayout backgroundColor="{{ ans4Bg }}" borderWidth="2" borderColor="#000000" borderRadius="10" padding="4 10" margin="0 3">
                                <Label text="{{ ans4Text }}" fontSize="12" fontWeight="bold" color="{{ ans4Fg }}" textAlignment="center" />
                            </StackLayout>
                        </StackLayout>
                    </StackLayout>
                </StackLayout>
            </ScrollView>

            <!-- Bottom Play Again Button with Explicit Height -->
            <StackLayout row="2" margin="4 0 0 0">
                <Button tap="restartGame" height="58" backgroundColor="#ffee00" color="#000000" borderRadius="29" borderWidth="3" borderColor="#000000" verticalAlignment="center">
                    <FormattedString>
                        <Span text="&#xf01e;" class="fas" fontSize="16" />
                        <Span text="  " />
                        <Span text="{{ L('btn_restart') }}" fontSize="18" fontWeight="bold" />
                    </FormattedString>
                </Button>
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
