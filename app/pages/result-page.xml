<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    xmlns:canvas="@nativescript/canvas"
    navigatingTo="onNavigatingTo" 
    actionBarHidden="true"
    class="bg-indigo-950 text-white">

    <GridLayout rows="*">
        <!-- Confetti Canvas Background Layer -->
        <canvas:Canvas id="confettiCanvas" row="0" width="100%" height="100%" ready="onCanvasReady" />

        <!-- UI Content Layer -->
        <GridLayout row="0" rows="*, auto">
            <!-- Main Content Area -->
            <StackLayout row="0" verticalAlignment="center" horizontalAlignment="center" class="px-6 text-center">
                <!-- Loading State -->
                <StackLayout visibility="{{ isLoading ? 'visible' : 'collapsed' }}" class="space-y-4">
                    <ActivityIndicator busy="true" class="text-amber-300 w-16 h-16 self-center" />
                    <Label text="{{ L('loading_result') }}" class="text-amber-200 text-lg font-black tracking-wide" textWrap="true" />
                </StackLayout>

                <!-- Result Revealed State -->
                <StackLayout visibility="{{ !isLoading ? 'visible' : 'collapsed' }}" class="space-y-6">
                    <StackLayout class="badge-amber rounded-full w-16 h-16 self-center mb-2 p-3" verticalAlignment="center" horizontalAlignment="center">
                        <Label text="&#xe05d;" class="fas text-3xl text-amber-300 text-center" />
                    </StackLayout>
                    <Label text="✨ {{ L('result_title') }} ✨" class="text-2xl font-black text-amber-300 uppercase tracking-widest" />
                    <Label text="{{ L('result_message') }}" class="text-indigo-100 text-lg font-bold" />
                    
                    <!-- Reveal Circle -->
                    <AbsoluteLayout class="w-56 h-56 self-center my-4">
                        <!-- Outer Glow Ring -->
                        <StackLayout class="w-56 h-56 badge-amber rounded-full opacity-60 animate-pulse" />
                        <!-- Inner Container -->
                        <GridLayout class="w-48 h-48 bg-gradient-to-br from-amber-400 to-amber-500 border-4 border-amber-300 rounded-full shadow-2xl m-4" verticalAlignment="center" horizontalAlignment="center">
                            <Label text="{{ result }}" class="text-center text-8xl font-black text-indigo-950" />
                        </GridLayout>
                    </AbsoluteLayout>
                </StackLayout>
            </StackLayout>

            <!-- Action Button Footer -->
            <StackLayout row="1" class="p-6" visibility="{{ !isLoading ? 'visible' : 'collapsed' }}">
                <Button tap="restartGame" class="bg-amber-400 active:bg-amber-300 text-indigo-950 font-black text-xl rounded-2xl py-4 btn-play border-2 border-amber-300">
                    <FormattedString>
                        <Span text="&#xf01e;" class="fas text-indigo-950" />
                        <Span text="&nbsp;&nbsp; " />
                        <Span text="{{ L('btn_restart') }}" />
                    </FormattedString>
                </Button>
            </StackLayout>
        </GridLayout>
    </GridLayout>
</Page>
