<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    navigatingTo="onNavigatingTo"
    actionBarHidden="true"
    backgroundColor="#f8fafc"
    color="#000000">

    <GridLayout rows="auto, auto, *" padding="16">
        <!-- Header -->
        <GridLayout row="0" columns="auto, *" width="100%" margin="0 0 12 0">
            <!-- Back Button -->
            <StackLayout col="0" tap="goBack" backgroundColor="#ffffff" borderWidth="2" borderColor="#000000" borderRadius="22" width="44" height="44" verticalAlignment="center" horizontalAlignment="center">
                <Label text="&#xf060;" class="fas" fontSize="16" color="#000000" textAlignment="center" verticalAlignment="center" />
            </StackLayout>

            <!-- Title Header -->
            <StackLayout col="1" margin="0 0 0 12" verticalAlignment="center">
                <StackLayout orientation="horizontal" verticalAlignment="center">
                    <Label text="&#xf0ad;" class="fas" fontSize="14" color="#a855f7" margin="0 6 0 0" />
                    <Label text="Developer Icon Inspector" fontSize="18" fontWeight="bold" color="#000000" />
                </StackLayout>
                <Label text="Preview all 31 items for each topic" fontSize="12" color="#64748b" />
            </StackLayout>
        </GridLayout>

        <!-- Topic Selector Horizontal Scroll Bar -->
        <ScrollView row="1" orientation="horizontal" margin="0 0 12 0">
            <StackLayout orientation="horizontal">
                <Button text="Animals" tap="selectTopicAnimals" backgroundColor="{{ activeTopic === 'animals' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 6 0 0" />
                <Button text="Vehicles" tap="selectTopicVehicles" backgroundColor="{{ activeTopic === 'vehicles' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 6 0 0" />
                <Button text="Plants" tap="selectTopicPlants" backgroundColor="{{ activeTopic === 'plants' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 6 0 0" />
                <Button text="Foods" tap="selectTopicFoods" backgroundColor="{{ activeTopic === 'foods' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 6 0 0" />
                <Button text="Sports" tap="selectTopicSports" backgroundColor="{{ activeTopic === 'sports' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 6 0 0" />
                <Button text="Brands" tap="selectTopicBrands" backgroundColor="{{ activeTopic === 'brands' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 6 0 0" />
                <Button text="Numbers" tap="selectTopicNumbers" backgroundColor="{{ activeTopic === 'numbers' ? '#ffee00' : '#ffffff' }}" color="#000000" fontWeight="bold" fontSize="12" borderWidth="2" borderColor="#000000" borderRadius="14" padding="8 14" margin="0 0 0 0" />
            </StackLayout>
        </ScrollView>

        <!-- Main Items ListView -->
        <ListView row="2" items="{{ topicItems }}" backgroundColor="transparent" separatorColor="transparent">
            <ListView.itemTemplate>
                <StackLayout backgroundColor="#ffffff" borderWidth="2" borderColor="#000000" borderRadius="16" padding="12 16" margin="0 0 10 0">
                    <GridLayout columns="auto, *, auto" width="100%">
                        <!-- Value Badge -->
                        <StackLayout col="0" backgroundColor="#00e5ff" borderWidth="2" borderColor="#000000" borderRadius="14" width="42" height="42" verticalAlignment="center" horizontalAlignment="center">
                            <Label text="{{ valueStr }}" fontSize="12" fontWeight="bold" color="#000000" textAlignment="center" verticalAlignment="center" width="100%" />
                        </StackLayout>

                        <!-- Icon & Label Name Details -->
                        <GridLayout col="1" columns="auto, *" margin="0 12" verticalAlignment="center">
                            <!-- Icon -->
                            <StackLayout col="0" backgroundColor="#ffee00" borderWidth="2" borderColor="#000000" borderRadius="14" width="48" height="48" verticalAlignment="center" horizontalAlignment="center" margin="0 12 0 0">
                                <Label text="{{ icon }}" class="{{ fontClass }}" fontSize="24" color="#000000" textAlignment="center" verticalAlignment="center" />
                            </StackLayout>

                            <!-- Names with textWrap="true" -->
                            <StackLayout col="1" verticalAlignment="center">
                                <Label text="{{ nameEn }}" fontSize="15" fontWeight="bold" color="#000000" textWrap="true" />
                                <Label text="{{ nameId }}" fontSize="12" color="#64748b" textWrap="true" />
                            </StackLayout>
                        </GridLayout>

                        <!-- Font Class Badge -->
                        <StackLayout col="2" backgroundColor="#fef9c3" borderWidth="1.5" borderColor="#000000" borderRadius="10" padding="4 8" verticalAlignment="center">
                            <Label text="{{ fontClass }}" fontSize="11" fontWeight="bold" color="#000000" textAlignment="center" />
                        </StackLayout>
                    </GridLayout>
                </StackLayout>
            </ListView.itemTemplate>
        </ListView>
    </GridLayout>
</Page>
