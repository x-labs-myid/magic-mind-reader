<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    navigatingTo="onNavigatingTo"
    actionBarHidden="true"
    backgroundColor="#ffffff"
    color="#000000">

    <GridLayout rows="auto, *" padding="16">
        <!-- Header -->
        <GridLayout row="0" columns="auto, *" width="100%" margin="0 0 12 0">
            <!-- Back Button -->
            <StackLayout col="0" tap="goBack" backgroundColor="#ffffff" borderWidth="2" borderColor="#000000" borderRadius="22" width="44" height="44" verticalAlignment="center" horizontalAlignment="center">
                <Label text="&#xf060;" class="fas" fontSize="16" color="#000000" textAlignment="center" verticalAlignment="center" />
            </StackLayout>

            <!-- Title Header -->
            <StackLayout col="1" margin="0 0 0 12" verticalAlignment="center">
                <Label text="{{ L('about_title') }}" fontSize="18" fontWeight="bold" color="#000000" />
            </StackLayout>
        </GridLayout>

        <!-- About Content Card -->
        <ScrollView row="1" verticalAlignment="top">
            <StackLayout margin="8 0">
                <!-- App Header Banner -->
                <StackLayout backgroundColor="#ffee00" borderWidth="3" borderColor="#000000" borderRadius="24" padding="24 16" textAlignment="center" margin="0 0 16 0">
                    <StackLayout backgroundColor="#ff9800" borderWidth="2" borderColor="#000000" borderRadius="36" width="72" height="72" horizontalAlignment="center" margin="0 0 12 0" verticalAlignment="center">
                        <Label text="&#xf25a;" class="fas" fontSize="36" color="#000000" textAlignment="center" verticalAlignment="center" />
                    </StackLayout>
                    <Label text="{{ L('title') }}" fontSize="22" fontWeight="bold" color="#000000" textAlignment="center" margin="0 0 4 0" />
                    <Label text="Version 2.0.0" fontSize="12" fontWeight="bold" color="#000000" />
                </StackLayout>

                <!-- About Description Card -->
                <StackLayout backgroundColor="#ffffff" borderWidth="3" borderColor="#000000" borderRadius="20" padding="20" margin="0 0 16 0">
                    <Label text="{{ L('about_desc') }}" fontSize="14" color="#000000" textWrap="true" />
                </StackLayout>

                <!-- Credits Section -->
                <StackLayout backgroundColor="#ffffff" borderWidth="3" borderColor="#000000" borderRadius="20" padding="20">
                    <Label text="{{ L('about_credits') }}" fontSize="16" fontWeight="bold" color="#000000" margin="0 0 12 0" />
                    
                    <!-- Developer (Tap to open Developer Icon Preview) -->
                    <GridLayout columns="auto, *" margin="0 0 10 0" tap="goDevPreview">
                        <Label col="0" text="&#xf007;" class="fas" fontSize="18" color="#ff9800" width="30" verticalAlignment="center" />
                        <StackLayout col="1">
                            <Label text="Developer" fontSize="12" color="#64748b" fontWeight="bold" />
                            <Label text="Kang Cahya 🛠️" fontSize="14" fontWeight="bold" color="#000000" />
                        </StackLayout>
                    </GridLayout>

                    <!-- Iconography -->
                    <GridLayout columns="auto, *">
                        <Label col="0" text="&#xf35b;" class="fas" fontSize="18" color="#00e5ff" width="30" verticalAlignment="center" />
                        <StackLayout col="1">
                            <Label text="Icons" fontSize="12" color="#64748b" fontWeight="bold" />
                            <Label text="FontAwesome 7 Free" fontSize="14" fontWeight="bold" color="#000000" />
                        </StackLayout>
                    </GridLayout>
                </StackLayout>
            </StackLayout>
        </ScrollView>
    </GridLayout>
</Page>
