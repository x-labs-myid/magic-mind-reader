<Page 
    xmlns="http://schemas.nativescript.org/tns.xsd" 
    actionBarHidden="true"
    class="bg-indigo-950 text-white">

    <GridLayout rows="auto, *, auto" class="p-6">
        <!-- Header with Back Button -->
        <GridLayout row="0" columns="auto, *" class="w-full mb-4">
            <Button col="0" tap="goBack" class="text-lg btn-header active:bg-indigo-800 rounded-full w-12 h-12 text-amber-300 border shadow-md">
                <FormattedString>
                    <Span text="&#xf060;" class="fas" />
                </FormattedString>
            </Button>
            <Label col="1" text="{{ L('about_title') }}" class="text-2xl font-black self-center ml-4 text-amber-300" />
        </GridLayout>

        <!-- Scrollable content -->
        <ScrollView row="1" class="w-full">
            <StackLayout class="space-y-6 text-center">
                <!-- App Logo Image -->
                <Image src="~/assets/images/logo.png" width="120" height="120" class="self-center my-4" />

                <!-- App Version -->
                <Label text="Version 2.0.0" class="text-xs font-black text-amber-400 tracking-widest uppercase badge-amber rounded-full px-4 py-1 self-center" />

                <!-- About Description -->
                <Label text="{{ L('about_desc') }}" class="text-sm leading-relaxed text-indigo-100 btn-header border rounded-3xl p-6 text-left shadow-xl" textWrap="true" />

                <!-- Credits Section -->
                <StackLayout class="btn-header border rounded-3xl p-6 text-left space-y-4 shadow-xl">
                    <Label text="{{ L('about_credits') }}" class="text-base font-black text-amber-300 border-b border-indigo-700 pb-2" />
                    
                    <!-- Developer -->
                    <GridLayout columns="auto, *" class="gap-3">
                        <Label col="0" text="&#xf007;" class="fas text-amber-400 text-lg w-6" />
                        <StackLayout col="1">
                            <Label text="Developer" class="text-xs text-indigo-300" />
                            <Label text="Cahya" class="text-sm font-extrabold text-white" />
                        </StackLayout>
                    </GridLayout>

                    <!-- Iconography -->
                    <GridLayout columns="auto, *" class="gap-3">
                        <Label col="0" text="&#xf2b7;" class="fab text-amber-400 text-lg w-6" />
                        <StackLayout col="1">
                            <Label text="Iconography" class="text-xs text-indigo-300" />
                            <Label text="FontAwesome Free" class="text-sm font-extrabold text-white" />
                        </StackLayout>
                    </GridLayout>

                    <!-- Framework -->
                    <GridLayout columns="auto, *" class="gap-3">
                        <Label col="0" text="&#xf10b;" class="fas text-amber-400 text-lg w-6" />
                        <StackLayout col="1">
                            <Label text="Framework" class="text-xs text-indigo-300" />
                            <Label text="NativeScript 9 &amp; Webpack" class="text-sm font-extrabold text-white" />
                        </StackLayout>
                    </GridLayout>
                </StackLayout>
            </StackLayout>
        </ScrollView>

        <!-- Footer -->
        <StackLayout row="2" class="text-center pt-4 pb-2">
            <Label text="© 2026 x-labs.my.id. All rights reserved." class="text-xs footer-text font-semibold" />
        </StackLayout>
    </GridLayout>
</Page>
